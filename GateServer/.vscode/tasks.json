{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++-11 生成活动文件",
            "command": "/usr/bin/bash",
            "args": [
                "-lc",
                "PKG_CONFIG_PATH=/home/zdc/.local/lib/pkgconfig /usr/bin/g++-11 -fdiagnostics-color=always -g *.cpp *.cc -o \"${fileDirname}/${fileBasenameNoExtension}\" -I/home/zdc/.local/include -I/usr/include/jsoncpp -L/home/zdc/.local/lib -ljsoncpp -lboost_filesystem $(PKG_CONFIG_PATH=/home/zdc/.local/lib/pkgconfig pkg-config --libs --static grpc++_unsecure protobuf) -pthread"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}
